# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# AI Provider
# OpenRouter-compatible fallback chain.
OPENROUTER_API_KEY=your_openrouter_api_key
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODELS=openai/gpt-oss-20b:free,google/gemma-4-26b-a4b-it:free,nvidia/nemotron-nano-9b-v2:free

# Legacy single-model override. Leave empty to use AI_MODELS above.
AI_MODEL=

# App
APP_TIMEZONE=Asia/Jakarta
DATABASE_URL=sqlite:///study_bot.db

# Reminder
REMINDER_CHECK_INTERVAL_SECONDS=60
